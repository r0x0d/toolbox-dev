#!/usr/bin/env bash
set -euo pipefail

keep_backup=false
while [[ $# -gt 0 ]]; do
    case "$1" in
        --keep-backup|-k)
            keep_backup=true
            shift
            ;;
        -h|--help)
            echo "Usage: tdx-upgrade [--keep-backup|-k]"
            echo "  --keep-backup, -k  Preserve the old backup container after upgrade"
            exit 0
            ;;
        *)
            echo "Unknown option: $1" >&2
            exit 1
            ;;
    esac
done

if [ ! -r /run/.containerenv ] || [ ! -r /run/.toolboxenv ]; then
    echo "Error: tdx-upgrade can only be run from within a toolbox container." >&2
    exit 1
fi

# Read container metadata
# shellcheck source=/dev/null
source /run/.containerenv
toolbox_name="${name:?}"
toolbox_image="${image:?}"

if ! /usr/bin/podman-remote ps --quiet >/dev/null 2>&1; then
    echo "Error: podman socket is not available on the host." >&2
    echo "Run on the host: systemctl --user enable --now podman.socket" >&2
    exit 1
fi

echo "Checking for updates to $toolbox_image..."

local_digest=$(/usr/bin/podman-remote inspect "$toolbox_name" | /usr/bin/jq -r ".[0].ImageDigest")
remote_digest=$(/usr/local/bin/skopeo inspect "docker://$toolbox_image" | /usr/bin/jq -r .Digest)

if [ "$local_digest" = "$remote_digest" ]; then
    echo "Already running the latest image. No upgrade needed."
    exit 0
fi

echo "A newer image is available. Upgrading..."
/usr/bin/podman-remote pull "$toolbox_image"

# Rename current container as backup
toolbox_backup="${toolbox_name}_$(date +%Y-%m-%d-%H%M%S)"
echo "Renaming current container to $toolbox_backup..."
/usr/bin/podman-remote rename "$toolbox_name" "$toolbox_backup"

# Create new container from latest image
echo "Creating new container..."
/usr/bin/toolbox create --image "$toolbox_image" "$toolbox_name"

# Run tdx-apply before entering so the user's login shell (e.g. fish)
# is available when toolbox enter tries to use it
TDX_CONFIG="${TDX_CONFIG:-$HOME/.config/toolbox-dev/config.yml}"
if [ -f "$TDX_CONFIG" ]; then
    echo "Applying configuration to new container..."
    /usr/bin/toolbox run -c "$toolbox_name" tdx-apply
fi

echo "Upgrade complete. Entering new container..."
/usr/bin/toolbox enter "$toolbox_name"

# Remove old container unless --keep-backup was specified
if [ "$keep_backup" = true ]; then
    echo "Backup container preserved as $toolbox_backup"
else
    /usr/bin/toolbox rm "$toolbox_backup" --force
fi
